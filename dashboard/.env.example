PORT=3003
LOS_URL=http://localhost:3333
LOS_USERNAME=analyst01
LOS_PASSWORD=bms2025
LOS_LOGIN_PATH=/login
NODE_ENV=development
DB_PATH=../data/los.db
MOCK_AGENT=false

# LLM_PROVIDER: anthropic (default), gemini, or custom (OpenAI-compatible)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Custom OpenAI-compatible endpoint (OpenRouter, Ollama, vLLM, etc.)
CUSTOM_LLM_ENDPOINT=https://api.openai.com/v1
CUSTOM_LLM_MODEL=gpt-4o
CUSTOM_LLM_API_KEY=sk-...

# EXTRACTION_MODE: browser (default) — browser_use LLM reads data from LOS UI
#                  api               — fetches data directly from LOS REST API (fast, no LLM navigation)
EXTRACTION_MODE=browser
