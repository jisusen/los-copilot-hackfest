{
  "name": "aji-copilot-dashboard",
  "version": "1.0.0",
  "scripts": {
    "build:js": "bun run build.ts",
    "build:css": "bunx tailwindcss -i ./client/index.css -o ./dist/main.css",
    "build": "bun run build:js && bun run build:css && bun build client/main.tsx --outdir dist --target browser",
    "dev": "bun run build.ts && bun run --watch server/index.ts",
    "start": "bun run server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@google/genai": "^1.50.1",
    "@lottiefiles/react-lottie-player": "^3.6.0",
    "driver.js": "^1.4.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "bun-css-loader": "^1.4.2",
    "postcss": "^8.5.15",
    "tailwindcss": "3",
    "typescript": "^5.5.3"
  }
}
